{
  "name": "blogv2",
  "version": "1.0.0",
  "description": "just a blog",
  "private": true,
  "egg": {
    "typescript": true,
    "declarations": true
  },
  "scripts": {
    "start": "egg-scripts start --title=egg-server-blog",
    "stop": "egg-scripts stop --title=egg-server-blog",
    "dev": "egg-bin dev",
    "debug": "egg-bin debug",
    "test-local": "egg-bin test",
    "test": "npm run lint -- --fix && npm run test-local",
    "cov": "egg-bin cov",
    "tsc": "ets && tsc -p tsconfig.json",
    "ci": "npm run lint && npm run cov && npm run tsc",
    "autod": "autod",
    "lint": "eslint . --ext .ts",
    "clean": "ets clean"
  },
  "dependencies": {
    "@types/highlight.js": "^10.1.0",
    "axios": "^0.26.1",
    "egg": "^2.6.1",
    "egg-es": "^1.2.3",
    "egg-scripts": "^2.6.0",
    "egg-sequelize": "^6.0.0",
    "egg-view-nunjucks": "^2.3.0",
    "highlight.js": "^11.4.0",
    "moment": "^2.29.3",
    "mysql2": "^2.3.3",
    "sequelize": "^6.19.0"
  },
  "devDependencies": {
    "@types/http-assert": "^1.5.3",
    "@types/marked": "^4.0.2",
    "@types/mocha": "^2.2.40",
    "@types/moment": "^2.13.0",
    "@types/node": "^7.10.14",
    "@types/supertest": "^2.0.0",
    "autod": "^3.0.1",
    "autod-egg": "^1.1.0",
    "egg-bin": "^4.11.0",
    "egg-ci": "^1.8.0",
    "egg-mock": "^3.16.0",
    "eslint": "^6.7.2",
    "eslint-config-egg": "^8.0.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.1",
    "marked": "^4.0.12",
    "sequelize-cli": "^6.4.1",
    "tslib": "^1.9.0",
    "typescript": "^4.6.3"
  },
  "engines": {
    "node": ">=8.9.0"
  },
  "ci": {
    "version": "8"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "eslintIgnore": [
    "coverage"
  ],
  "author": "feiyyx",
  "license": "MIT"
}
